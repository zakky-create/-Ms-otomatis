local player = game.Players.LocalPlayer
local storeRemote = game:GetService("ReplicatedStorage"):WaitForChild("RemoteEvents"):WaitForChild("StorePurchase")

-- STATE
local buying = false
local buyAmount = 1

-- GUI
local gui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))
gui.ResetOnSpawn = false

local frame = Instance.new("Frame", gui)
frame.Size = UDim2.new(0,220,0,160)
frame.Position = UDim2.new(0.5,-110,0.5,-80)
frame.BackgroundColor3 = Color3.fromRGB(30,30,30)
frame.Active = true
frame.Draggable = true

Instance.new("UICorner", frame).CornerRadius = UDim.new(0,10)

local title = Instance.new("TextLabel", frame)
title.Size = UDim2.new(1,0,0,30)
title.BackgroundTransparency = 1
title.Text = "AUTO BUY"
title.TextColor3 = Color3.new(1,1,1)
title.Font = Enum.Font.GothamBold

-- BUTTON
local button = Instance.new("TextButton", frame)
button.Size = UDim2.new(0.9,0,0,40)
button.Position = UDim2.new(0.05,0,0,40)
button.Text = "AUTO BUY : OFF"
button.BackgroundColor3 = Color3.fromRGB(60,60,60)
button.TextColor3 = Color3.new(1,1,1)

Instance.new("UICorner", button)

-- INPUT (jumlah beli)
local box = Instance.new("TextBox", frame)
box.Size = UDim2.new(0.9,0,0,30)
box.Position = UDim2.new(0.05,0,0,95)
box.PlaceholderText = "Masukkan jumlah (contoh: 5)"
box.Text = ""
box.BackgroundColor3 = Color3.fromRGB(50,50,50)
box.TextColor3 = Color3.new(1,1,1)

Instance.new("UICorner", box)

-- fungsi beli
local function buy(item)
	local args = {item}
	pcall(function()
		storeRemote:FireServer(unpack(args))
	end)
end

-- AUTO BUY
local function autoBuy()
	while buying do
		
		for i = 1, buyAmount do
			if not buying then break end
			
			buy("Water")
			task.wait(0.2)
			
			buy("Sugar Block Bag")
			task.wait(0.2)
			
			buy("Gelatin")
			task.wait(0.2)
		end
		
		task.wait(1)
	end
end

-- tombol
button.MouseButton1Click:Connect(function()
	
	local num = tonumber(box.Text)
	if num then
		buyAmount = num
	end
	
	buying = not buying
	button.Text = buying and "AUTO BUY : ON" or "AUTO BUY : OFF"

	if buying then
		task.spawn(autoBuy)
	end
end)

