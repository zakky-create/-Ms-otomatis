-- cari NPC Lamont Bell
local function getLamont()

    for _,v in pairs(workspace:GetDescendants()) do
        if v.Name == "Lamont Bell" then
            return v
        end
    end

end


-- tekan prompt NPC
local function pressLamontPrompt()

    local npc = getLamont()

    if not npc then
        warn("Lamont Bell tidak ditemukan")
        return
    end

    for _,v in pairs(npc:GetDescendants()) do

        if v:IsA("ProximityPrompt") then
            fireproximityprompt(v,3)
            return
        end

    end

end


-- klik tombol GUI shop
local function clickButton(text)

    for _,v in pairs(player.PlayerGui:GetDescendants()) do

        if v:IsA("GuiButton") then

            if v.Text and string.find(string.lower(v.Text), string.lower(text)) then
                v:Activate()
                return true
            end

        end

    end

end


-- AutoBuy
local function autoBuy()

    pressLamontPrompt()

