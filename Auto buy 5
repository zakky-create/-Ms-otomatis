-- fungsi tambah item
local function giveItem(name)

    local tool = game.ReplicatedStorage:FindFirstChild(name)

    if tool then
        local clone = tool:Clone()
        clone.Parent = backpack
    end

end

-- cek jarak ke Lamont Bell
local function nearNPC()

    local npc = workspace:FindFirstChild("Lamont Bell")

    if npc and npc:FindFirstChild("HumanoidRootPart") then

        local root = player.Character.HumanoidRootPart
        local dist = (root.Position - npc.HumanoidRootPart.Position).Magnitude

        return dist < 15

    end

end

-- AutoBuy
button.MouseButton1Click:Connect(function()

    if nearNPC() then

        giveItem("Water")
        giveItem("Sugar Block Bag")
        giveItem("Gelatin")

        print("Bahan Marshmallow didapat")

    else

        print("Dekati NPC Lamont Bell dulu")

    end

end)



