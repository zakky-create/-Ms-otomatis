-- cek jarak ke Lamont Bell
local function nearLamont()

    local npc = workspace:FindFirstChild("Lamont Bell")

    if npc and npc:FindFirstChild("HumanoidRootPart") then

        local root = player.Character:WaitForChild("HumanoidRootPart")
        local dist = (root.Position - npc.HumanoidRootPart.Position).Magnitude

        return dist < 12

    end

    return false

end


-- klik tombol GUI shop
local function clickButton(text)

    while true do

        for _,v in pairs(player.PlayerGui:GetDescendants()) do

            if v:IsA("GuiButton") and v.Text then

                if string.find(string.lower(v.Text), string.lower(text)) then
                    v:Activate()
                    return
                end

            end

        end

        task.wait(0.3)

    end

end


-- buka toko (press E)
local function openShop()

    for _,v in pairs(workspace:GetDescendants()) do

        if v:IsA("ProximityPrompt") then

            if v.Parent and v.Parent.Parent then

                if string.find(v.Parent.Parent.Name,"Lamont") then
                    fireproximityprompt(v,5)
                    return
                end

            end

        end

    end

end


-- AutoBuy
