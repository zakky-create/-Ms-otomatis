local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local camera = workspace.CurrentCamera

local AimEnabled = false

-- GUI
local gui = Instance.new("ScreenGui")
gui.Parent = player:WaitForChild("PlayerGui")

local button = Instance.new("TextButton")
button.Parent = gui
button.Size = UDim2.new(0,120,0,40)
button.Position = UDim2.new(0,20,0.6,0)
button.Text = "AIM OFF"

button.MouseButton1Click:Connect(function()
	AimEnabled = not AimEnabled
	
	if AimEnabled then
		button.Text = "AIM ON"
	else
		button.Text = "AIM OFF"
	end
end)

-- cari target terdekat
local function getClosestTarget()

	local closest
	local shortest = math.huge

	for _,v in pairs(Players:GetPlayers()) do
		
		if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
			
			local HumanoidRootPart = v.Character.HumanoidRootPart
			local distance = (HumanoidRootPart.Position - camera.CFrame.Position).Magnitude

			if distance < shortest then
				shortest = distance
				closest = HumanoidRootPart
			end
			
		end
		
	end

	return closest
end

RunService.RenderStepped:Connect(function()

	if AimEnabled then
		
		local target = getClosestTarget()
		
		if target then
			
			local camPos = camera.CFrame.Position
			local distance = (target.Position - camPos).Magnitude
			
			-- kamera diarahkan lebih ke bawah
			local offset = distance / 6
			
			local aimPos = target.Position - Vector3.new(0, 5, 0)

			camera.CFrame = camera.CFrame:Lerp(
				CFrame.new(camPos, aimPos),
				0.3
			)
			
		end
		
	end

end)

