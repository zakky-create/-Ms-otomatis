-- Aim Bot for South Bronx in Roblox

-- Configuration
local aimbotEnabled = true
local aimbotFOV = 90
local aimbotSpeed = 10
local guiEnabled = true

-- Variables
local player = game.Players.LocalPlayer
local character = player.Character
local humanoid = character:WaitForChild("Humanoid")
local camera = game.Workspace.CurrentCamera
local aimpart = character:WaitForChild("Head")

-- GUI
if guiEnabled then
    local gui = Instance.new("ScreenGui")
    gui.Name = "AimBotGUI"
    gui.Parent = player.PlayerGui

    local frame = Instance.new("Frame")
    frame.Name = "Frame"
    frame.Size = UDim2.new(0, 200, 0, 100)
    frame.Position = UDim2.new(0, 10, 0, 10)
    frame.Parent = gui

    local label = Instance.new("TextLabel")
    label.Name = "Label"
    label.Text = "Aim Bot"
    label.Size = UDim2.new(0, 100, 0, 20)
    label.Position = UDim2.new(0, 0, 0, 0)
    label.Parent = frame

    local toggle = Instance.new("TextButton")
    toggle.Name = "Toggle"
    toggle.Text = "Toggle"
    toggle.Size = UDim2.new(0, 100, 0, 20)
    toggle.Position = UDim2.new(0, 0, 0, 30)
    toggle.Parent = frame

    local fov = Instance.new("TextButton")
    fov.Name = "FOV"
    fov.Text = "FOV: " .. aimbotFOV
    fov.Size = UDim2.new(0, 100, 0, 20)
    fov.Position = UDim2.new(0, 0, 0, 60)
    fov.Parent = frame

    local speed = Instance.new("TextButton")
    speed.Name = "Speed"
    speed.Text = "Speed: " .. aimbotSpeed
    speed.Size = UDim2.new(0, 100, 0, 20)
    speed.Position = UDim2.new(0, 0, 0, 90)
    speed.Parent = frame

    local function updateGUI()
        fov.Text = "FOV: " .. aimbotFOV
        speed.Text = "Speed: " .. aimbotSpeed
    end

    toggle.MouseButton1Click:Connect(function()
        aimbotEnabled = not aimbotEnabled
        if aimbotEnabled then
            toggle.Text = "Disable"
        else
            toggle.Text = "Enable"
        end
    end)

    updateGUI()
end

-- Aim Bot
if aimbotEnabled then
    local function aim()
        local closestPlayer = nil
        local closestDistance = math.huge

        for _, player in pairs(game.Players:GetPlayers()) do
            if player ~= game.Players.LocalPlayer and player.Character then
                local distance = (player.Character.HumanoidRootPart.Position - character.HumanoidRootPart.Position).magnitude
                if distance < closestDistance then
                    closestPlayer = player
                    closestDistance = distance
                end
            end
        end

        if closestPlayer then
            local direction = (closestPlayer.Character.HumanoidRootPart.Position - character.HumanoidRootPart.Position).unit
            local angle = math.deg(math.atan2(direction.Z, direction.X))

            if math.abs(angle - camera.CFrame.LookVector.Y) > aimbotFOV / 2 then
                local targetAngle = math.min(math.max(angle, -aimbotFOV / 2), aimbotFOV / 2)
                camera.CFrame = camera.CFrame * CFrame.Angles(0, math.rad(targetAngle - camera.CFrame.LookVector.Y), 0)
            end
        end
    end

    while true do
        aim()
        wait(aimbotSpeed / 60)
    end
end
