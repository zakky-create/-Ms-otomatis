-- ============================================================================
-- HELPER: Safe teleport dengan check
-- ============================================================================

local function safeTeleport(targetPosition, approachOffset)
    local character = player.Character
    if not character then
        print("❌ Character tidak ditemukan")
        return false
    end
    
    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
    if not humanoidRootPart then
        print("❌ HumanoidRootPart tidak ditemukan")
        return false
    end
    
    -- Teleport dengan offset (jangan langsung di NPC)
    local safePosition = targetPosition + approachOffset
    humanoidRootPart.CFrame = CFrame.new(safePosition)
    
    print("📍 Teleported to: " .. tostring(safePosition))
    task.wait(CONFIG.MOVEMENT_DELAY)
    
    return true
end

-- ============================================================================
-- HELPER: Find NPC by name
-- ============================================================================

local function findNPC(npcName)
    local workspace = game:GetService("Workspace")
    
    local npc = workspace:FindFirstChild(npcName)
    if npc then return npc end
    
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj.Name == npcName then
            return obj
        end
    end
    
    return nil
end

-- ============================================================================
-- HELPER: Find ProximityPrompt near location
-- ============================================================================

local function findProximityPromptNear(location, radius)
    local workspace = game:GetService("Workspace")
    local parts = workspace:FindPartBoundsInRadius(location, radius)
    
    for _, part in pairs(parts) do
        local prompt = part:FindFirstChild("ProximityPrompt")
        if prompt then
            print("✅ ProximityPrompt ditemukan: " .. part.Name)
            return prompt
        end
    end
    
    print("⚠️ ProximityPrompt tidak ditemukan dalam radius " .. radius)
    return nil
end

-- ============================================================================
-- HELPER: Trigger ProximityPrompt safely
-- ============================================================================

local function triggerProximityPrompt(prompt)
    if not prompt then
        print("❌ ProximityPrompt adalah nil")
        return false
    end
    
    if prompt:IsA("ProximityPrompt") then
        print("🔘 Triggering ProximityPrompt...")
        fireproximityprompt(prompt)
        task.wait(0.3)
        return true
    end
    
    print("❌ Object bukan ProximityPrompt")
    return false
end

