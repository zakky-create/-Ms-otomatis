    print("✅ Teleported to: " .. tostring(safePosition))
    
    task.wait(1)
    screenGui:Destroy()
    
    updateActivity()
end

-- ============================================================================
-- AUTO BUY MATERIALS ROUTINE (FIXED)
-- ============================================================================

local function buyMaterialsRoutine(quantity)
    print("💰 Buying " .. quantity .. " materials...")
    teleportWithAnimation(CONFIG.NPC_SELLER_LOCATION, CONFIG.NPC_APPROACH_OFFSET)
    task.wait(2)
    
    local character = player.Character
    if not character then
        print("❌ Character hilang")
        return
    end
    
    local npc = findNPC(CONFIG.NPC_NAME)
    if npc then
        print("✅ Found NPC: " .. npc.Name)
    else
        print("❌ NPC tidak ditemukan")
        return
    end
    
    for i = 1, quantity do
        if not (player.Character and player.Character:FindFirstChild("HumanoidRootPart")) then
            print("❌ Character respawn/hilang")
            break
        end
        
        print("Buying materials " .. i .. "/" .. quantity)
        
        -- Cari dan trigger ProximityPrompt
        local prompt = findProximityPromptNear(CONFIG.NPC_SELLER_LOCATION, 25)
        if prompt then
            triggerProximityPrompt(prompt)
        end
        
        task.wait(0.8)
        updateActivity()
        
        if i % 10 == 0 then
            task.wait(1)
        end
    end
    
    print("✅ Finished buying materials!")
end

-- ============================================================================
-- AUTO COOKING ROUTINE
-- ============================================================================

local function autoCookMarshmallows()
    if State.isCooking then return end
    State.isCooking = true
    
    print("🍲 Starting cooking process...")
    
    local marshmallowsMade = 0
    local targetMarshmallows = State.materialsToMake
    
    while State.isAutoMSEnabled and marshmallowsMade < targetMarshmallows do
        local character = player.Character
        if not character or not character:FindFirstChild("HumanoidRootPart") then
            print("❌ Character tidak ditemukan")
            break
        end
        
        print("Cooking marshmallow " .. (marshmallowsMade + 1) .. "/" .. targetMarshmallows)
        
        local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
        if humanoidRootPart then
            humanoidRootPart.CFrame = CFrame.new(CONFIG.STOVE_LOCATION + CONFIG.STOVE_APPROACH_OFFSET)
            task.wait(1)
            
            local stovePrompt = findProximityPromptNear(CONFIG.STOVE_LOCATION, 25)
            if stovePrompt then
                triggerProximityPrompt(stovePrompt)
            end
        end
        
        task.wait(CONFIG.STOVE_WAIT_TIME)
        updateActivity()
        task.wait(CONFIG.SECOND_COOK_WAIT_TIME)
        updateActivity()
        
        marshmallowsMade = marshmallowsMade + 1
        State.currentMarshmallows = marshmallowsMade
        
        task.wait(1)
    end
    
    State.isCooking = false
    State.isAutoMSEnabled = false
    print("✅ Cooking complete!")
end

