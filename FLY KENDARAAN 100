end)

-- START FLY LOOP

task.spawn(function()
	while wait(1) do
		if getVehicle() then
			startFly()
		end
	end
end)

-- Noclip
game:GetService("RunService").Stepped:Connect(function()
	if flying then
		for _,v in pairs(char:GetDescendants()) do
			if v:IsA("BasePart") then
				v.CanCollide = false
			end
		end
	end
end)
