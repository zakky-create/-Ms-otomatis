-- AutoBuy Marshmallow GUI

local player = game.Players.LocalPlayer
local vim = game:GetService("VirtualInputManager")

-- GUI
local gui = Instance.new("ScreenGui")
gui.Parent = player:WaitForChild("PlayerGui")

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0,200,0,120)
frame.Position = UDim2.new(0.02,0,0.55,0)
frame.BackgroundColor3 = Color3.fromRGB(30,30,30)
frame.Active = true
frame.Draggable = true
frame.Parent = gui

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1,0,0,30)
title.Text = "AUTO BUY MS"
title.BackgroundColor3 = Color3.fromRGB(40,40,40)
title.TextColor3 = Color3.new(1,1,1)
title.TextScaled = true
title.Parent = frame

local buy = Instance.new("TextButton")
buy.Size = UDim2.new(0.8,0,0,35)
buy.Position = UDim2.new(0.1,0,0.5,0)
buy.Text = "AUTO BUY"
buy.BackgroundColor3 = Color3.fromRGB(60,60,60)
buy.TextColor3 = Color3.new(1,1,1)
buy.Parent = frame

-- fungsi tekan E
local function pressE(time)

    vim:SendKeyEvent(true, Enum.KeyCode.E, false, game)
    task.wait(time)
    vim:SendKeyEvent(false, Enum.KeyCode.E, false, game)

end

-- fungsi AutoBuy
local function autoBuy()

    -- buka toko (tahan lama)
    pressE(5)
    task.wait(2)

    -- beli Water
    pressE(0.2)
    task.wait(0.7)

    -- beli Sugar Block Bag
    pressE(0.2)
    task.wait(0.7)

    -- beli Gelatin
    pressE(0.2)

    print("Water, Sugar, Gelatin berhasil dibeli")

end

-- tombol GUI
buy.MouseButton1Click:Connect(function()
    autoBuy()
end)



