local player = game.Players.LocalPlayer
local vim = game:GetService("VirtualInputManager")

-- GUI
local gui = Instance.new("ScreenGui")
gui.Parent = player:WaitForChild("PlayerGui")

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0,200,0,120)
frame.Position = UDim2.new(0.02,0,0.55,0)
frame.BackgroundColor3 = Color3.fromRGB(30,30,30)
frame.Active = true
frame.Draggable = true
frame.Parent = gui

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1,0,0,30)
title.Text = "AUTO BUY MS"
title.BackgroundColor3 = Color3.fromRGB(40,40,40)
title.TextColor3 = Color3.new(1,1,1)
title.TextScaled = true
title.Parent = frame

local buyBtn = Instance.new("TextButton")
buyBtn.Size = UDim2.new(0.8,0,0,35)
buyBtn.Position = UDim2.new(0.1,0,0.5,0)
buyBtn.Text = "AUTO BUY"
buyBtn.BackgroundColor3 = Color3.fromRGB(60,60,60)
buyBtn.TextColor3 = Color3.new(1,1,1)
buyBtn.Parent = frame

-- tekan E
local function pressE(time)

    vim:SendKeyEvent(true, Enum.KeyCode.E, false, game)
    task.wait(time)
    vim:SendKeyEvent(false, Enum.KeyCode.E, false, game)

end

-- pilih dialog Yea... you the guy?
local function chooseDialogue()

    for i = 1,2 do

        for _,v in pairs(player.PlayerGui:GetDescendants()) do

            if v:IsA("TextButton") and string.find(v.Text,"Yea") then
                v:Activate()
                task.wait(1)
            end

        end

        task.wait(1)

    end

end

-- AutoBuy
local function autoBuy()

    -- buka NPC
    pressE(7)

    task.wait(2)

    -- pilih dialog
    chooseDialogue()

    task.wait(1)

    -- beli Water
    pressE(0.2)
    task.wait(0.7)

    -- beli Sugar
    pressE(0.2)
    task.wait(0.7)

    -- beli Gelatin
    pressE(0.2)

    print("Water, Sugar, Gelatin berhasil dibeli")

end

buyBtn.MouseButton1Click:Connect(function()
    autoBuy()
end)







