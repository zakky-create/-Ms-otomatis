-- Membuat aimbot
local Aimbot = {}
local AimbotTarget = nil
local AimbotSmooth = false

-- Event handler
local function onInput(Input)
    if Input.KeyCode == Enum.KeyCode.LeftShift then
        AimbotSmooth = not AimbotSmooth
    end
end

UserInputService.InputBegan:Connect(onInput)

-- Update aimbot
local function updateAimbot()
    if AimbotTarget then
        local AimbotPosition = AimbotTarget.Position
        local PlayerPosition = Players.LocalPlayer.Character.HumanoidRootPart.Position
        local AimbotDirection = (AimbotPosition - PlayerPosition).Unit
        local AimbotAngle = math.atan2(AimbotDirection.X, AimbotDirection.Z)
        local CameraAngle = math.atan2(-math.sin(PlayerPosition.X - PlayerPosition.Z), math.cos(PlayerPosition.X - PlayerPosition.Z))
        if AimbotSmooth then
            local AimbotSmoothAngle = math.clamp(AimbotAngle - CameraAngle, -0.1, 0.1)
            Players.LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(PlayerPosition) * CFrame.Angles(0, AimbotSmoothAngle, 0)
        else
            Players.LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(PlayerPosition) * CFrame.Angles(0, AimbotAngle, 0)
        end
    end
end

