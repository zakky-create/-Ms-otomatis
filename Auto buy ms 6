-- cari prompt Lamont Bell
local function getPrompt()

    for _,v in pairs(workspace:GetDescendants()) do
        if v:IsA("ProximityPrompt") then

            if v.Parent and v.Parent.Parent then
                if string.find(v.Parent.Parent.Name,"Lamont") then
                    return v
                end
            end

        end
    end

end

-- buka toko
local function openShop()

    local prompt = getPrompt()

    if prompt then
        fireproximityprompt(prompt,5)
    end

end

-- klik tombol GUI
local function clickButton(text)

    while true do

        for _,v in pairs(player.PlayerGui:GetDescendants()) do

            if v:IsA("TextButton") then

                if string.find(string.lower(v.Text), string.lower(text)) then
                    v:Activate()
                    return
                end

            end

        end

        task.wait(0.3)

    end

end

-- AutoBuy
