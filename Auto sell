-- AUTO SELL SOUTH BRONX

local player = game.Players.LocalPlayer
local backpack = player:WaitForChild("Backpack")
local running = false

-- Fungsi cek Marshmallow Bag
local function isMarshmallow(tool)
    return tool:IsA("Tool") and string.find(tool.Name,"Marshmallow Bag")
end

-- Fungsi jual ke Lamont Bell
local function sellToLamont()
    local npc = workspace:FindFirstChild("Lamont Bell")
    if npc then
        for _,v in pairs(npc:GetDescendants()) do
            if v:IsA("ProximityPrompt") then
                fireproximityprompt(v)
                task.wait(0.5) -- tunggu prompt selesai
            end
        end
    end
end

-- Fungsi AUTO SELL
local function autoSellFunc()
    while running do
        -- loop semua tool di backpack
        for _,tool in pairs(backpack:GetChildren()) do
            if not running then return end
            if isMarshmallow(tool) then
                player.Character.Humanoid:EquipTool(tool)
                task.wait(0.4)
                sellToLamont()
                task.wait(1)
            end
        end
        task.wait(1)
    end
end

-- Toggle AUTO SELL
local ScreenGui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))
local frame = Instance.new("Frame", ScreenGui)
frame.Size = UDim2.new(0,200,0,60)
frame.Position = UDim2.new(0.5,-100,0.5,-30)
frame.BackgroundColor3 = Color3.fromRGB(40,40,40)
frame.Active = true
frame.Draggable = true

local toggleBtn = Instance.new("TextButton", frame)
toggleBtn.Size = UDim2.new(1,0,1,0)
toggleBtn.Text = "AUTO SELL : OFF"
toggleBtn.TextColor3 = Color3.new(1,1,1)
toggleBtn.BackgroundColor3 = Color3.fromRGB(70,70,70)
toggleBtn.Font = Enum.Font.Gotham
toggleBtn.TextSize = 16

toggleBtn.MouseButton1Click:Connect(function()
    running = not running
    if running then
        toggleBtn.Text = "AUTO SELL : ON"
        task.spawn(autoSellFunc)
    else
        toggleBtn.Text = "AUTO SELL : OFF"
    end
end)

