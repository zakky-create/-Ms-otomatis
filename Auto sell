-- AUTO SELL LAMONT BELL

local player = game.Players.LocalPlayer
local backpack = player:WaitForChild("Backpack")
local PlayerGui = player:WaitForChild("PlayerGui")

-- GUI
local gui = Instance.new("ScreenGui", PlayerGui)
gui.Name = "AutoSellGui"
gui.ResetOnSpawn = false

local frame = Instance.new("Frame", gui)
frame.Size = UDim2.new(0,200,0,100)
frame.Position = UDim2.new(0.4,0,0.4,0)
frame.BackgroundColor3 = Color3.fromRGB(40,40,40)
frame.Active = true
frame.Draggable = true

local button = Instance.new("TextButton", frame)
button.Size = UDim2.new(1,0,1,0)
button.Text = "AUTO SELL : OFF"
button.BackgroundColor3 = Color3.fromRGB(70,70,70)
button.TextColor3 = Color3.new(1,1,1)

local enabled = false

-- cari bag
local function getBag()
    for _,v in pairs(backpack:GetChildren()) do
        if v:IsA("Tool") and string.find(v.Name,"Marshmallow") then
            return v
        end
    end
end

-- auto sell
task.spawn(function()
    while true do
        task.wait(0.5)

        if enabled then
            local bag = getBag()

            if bag then
                bag.Parent = player.Character
            end

            local prompt = workspace.Folders.NPCs["Lamont Bell"].UpperTorso.ProximityPrompt
            if prompt then
                fireproximityprompt(prompt)
            end
        end
    end
end)

button.MouseButton1Click:Connect(function()
    enabled = not enabled
    button.Text = enabled and "AUTO SELL : ON" or "AUTO SELL : OFF"
end)


