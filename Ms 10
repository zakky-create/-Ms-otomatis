-- COUNT ITEM
local function countItem(name)
	local amount = 0
	for _,v in pairs(backpack:GetChildren()) do
		if v.Name == name then
			amount += 1
		end
	end
	if player.Character then
		for _,v in pairs(player.Character:GetChildren()) do
			if v.Name == name then
				amount += 1
			end
		end
	end
	return amount
end

