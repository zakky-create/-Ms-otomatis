-- AUTO COOK
local cooking = false
local function autoCook()
	cooking = true
	while cooking do
		useTool("Water")
		pressCookPrompt()
		task.wait(21)
		useTool("Sugar Block Bag")
		useTool("Gelatin")
		pressCookPrompt()
		task.wait(46)
		useTool("Empty Bag")
		print("Marshmallow Finished")
		cooking = false -- hapus kalau mau loop terus
	end
end

