-- SLIDER SYSTEM
local UIS = game:GetService("UserInputService")

local dragging = false
local buyAmount = 1
local maxBuy = 100

local function updateSlider(x)

local barPos = sliderBar.AbsolutePosition.X
local barSize = sliderBar.AbsoluteSize.X

local percent = math.clamp((x - barPos) / barSize,0,1)

sliderFill.Size = UDim2.new(percent,0,1,0)
sliderButton.Position = UDim2.new(percent,-9,0.5,-9)

buyAmount = math.floor(1 + (maxBuy - 1) * percent + 0.5)

amountLabel.Text = "BUY AMOUNT : "..buyAmount

end

sliderBar.InputBegan:Connect(function(input)

if input.UserInputType == Enum.UserInputType.MouseButton1
or input.UserInputType == Enum.UserInputType.Touch then

dragging = true
updateSlider(input.Position.X)

end

end)

UIS.InputEnded:Connect(function(input)

if input.UserInputType == Enum.UserInputType.MouseButton1
or input.UserInputType == Enum.UserInputType.Touch then

dragging = false

end

end)

UIS.InputChanged:Connect(function(input)

if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement
or input.UserInputType == Enum.UserInputType.Touch) then

updateSlider(input.Position.X)

end

end)

-- AUTO BUY FIX (ANTI OVERBUY)

local buying = false

local function buy(item)
	local args = {item}
	pcall(function()
		storeRemote:FireServer(unpack(args))
	end)
end

local function autoBuyLoop()
	while buying do
		
		if countItem("Water") < buyAmount then
			buy("Water")
		end
		
		if countItem("Sugar Block Bag") < buyAmount then
			buy("Sugar Block Bag")
		end
		
		if countItem("Gelatin") < buyAmount then
			buy("Gelatin")
		end

		task.wait(0.5)
	end
end

autoBuy.MouseButton1Click:Connect(function()
	buying = not buying
	autoBuy.Text = buying and "AUTO BUY : ON" or "AUTO BUY : OFF"

	if buying then
		task.spawn(autoBuyLoop)
	end
end)

