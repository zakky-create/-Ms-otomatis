local player = game.Players.LocalPlayer
local size = 8
local enabled = false

-- GUI
local gui = Instance.new("ScreenGui", player.PlayerGui)

local frame = Instance.new("Frame", gui)
frame.Size = UDim2.new(0,200,0,120)
frame.Position = UDim2.new(0.03,0,0.4,0)
frame.BackgroundColor3 = Color3.fromRGB(173,216,230)
frame.Active = true
frame.Draggable = true

local title = Instance.new("TextLabel", frame)
title.Size = UDim2.new(1,0,0,30)
title.Text = "BIG HEAD"
title.BackgroundColor3 = Color3.fromRGB(120,190,220)
title.TextColor3 = Color3.new(1,1,1)
title.TextScaled = true

local toggle = Instance.new("TextButton", frame)
toggle.Size = UDim2.new(0.8,0,0,35)
toggle.Position = UDim2.new(0.1,0,0.45,0)
toggle.Text = "ENABLE"

local function addHitbox(char)

    local head = char:FindFirstChild("Head")
    if not head then return end

    if char:FindFirstChild("BigHitbox") then
        char.BigHitbox:Destroy()
    end

    local part = Instance.new("Part")
    part.Name = "BigHitbox"
    part.Shape = Enum.PartType.Ball
    part.Size = Vector3.new(size,size,size)
    part.Transparency = 1
    part.CanCollide = false
    part.Massless = true
    part.Parent = char

    part.CFrame = head.CFrame

    local weld = Instance.new("WeldConstraint")
    weld.Part0 = head
    weld.Part1 = part
    weld.Parent = part

end

local function apply()

    for _,v in pairs(game.Players:GetPlayers()) do
        if v ~= player and v.Character then

            if enabled then
                addHitbox(v.Character)
            else
                if v.Character:FindFirstChild("BigHitbox") then
                    v.Character.BigHitbox:Destroy()
                end
            end

        end
    end

end

toggle.MouseButton1Click:Connect(function()

    enabled = not enabled

    if enabled then
        toggle.Text = "DISABLE"
    else
        toggle.Text = "ENABLE"
    end

    apply()

end)

game.Players.PlayerAdded:Connect(function(plr)

    plr.CharacterAdded:Connect(function(char)

        task.wait(1)

        if enabled then
            addHitbox(char)
        end

    end)

end)

