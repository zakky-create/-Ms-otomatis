-- AUTO SELL

local selling = false

local function getPrompt()

	local npc = workspace.NPCs:FindFirstChild("Lamont Bell")

	if npc then
		return npc:FindFirstChildWhichIsA("ProximityPrompt", true)
	end

end

local function getBag()

	for _,tool in pairs(backpack:GetChildren()) do
		if tool:IsA("Tool") and string.find(tool.Name,"Marshmallow") then
			return tool
		end
	end

end

local function pressInteract(prompt)

	if prompt then
		prompt:InputHoldBegin()
		task.wait(0.5)
		prompt:InputHoldEnd()
	end

end

local function autoSellLoop()

	while selling do

		local bag = getBag()

		if not bag then
			selling = false
			autoSell.Text = "AUTO SELL : OFF"
			break
		end

		local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")

		if hum then
			hum:EquipTool(bag)
		end

		task.wait(0.3)

		local prompt = getPrompt()

		pressInteract(prompt)

		task.wait(0.6)

	end

end

autoSell.MouseButton1Click:Connect(function()

	selling = not selling
	autoSell.Text = selling and "AUTO SELL : ON" or "AUTO SELL : OFF"

	if selling then
		task.spawn(autoSellLoop)
	end

end)

-- TELEPORT
local NPC = Vector3.new(523,3,615)
local APT1 = Vector3.new(1202,3,-182)

local function getSeat()

local char = player.Character
if not char then return end

local humanoid = char:FindFirstChildOfClass("Humanoid")

if humanoid and humanoid.SeatPart then
return humanoid.SeatPart
end

end

local function teleport(pos)

local seat = getSeat()

if seat then

local vehicle = seat.Parent

for _,part in pairs(vehicle:GetDescendants()) do

if part:IsA("BasePart") then

local tween = TweenService:Create(
part,
TweenInfo.new(2),
{CFrame = part.CFrame + (pos - seat.Position)}
)

tween:Play()

end

end

end

end

tpNPC.MouseButton1Click:Connect(function()
teleport(NPC)
end)

tpAPT1.MouseButton1Click:Connect(function()
teleport(APT1)
end)

