local function createESP(targetplayer)

if targetplayer == player then return end  

local function setup(char)  

	local hrp = char:WaitForChild("HumanoidRootPart",5)  
	local hum = char:WaitForChild("Humanoid",5)  
	if not hrp then return end  

	local bill = Instance.new("BillboardGui")  
	bill.Size = UDim2.new(4,0,6,0)  
	bill.Adornee = hrp  
	bill.AlwaysOnTop = true  
	bill.MaxDistance = 10000  

	local function line(size,pos)  
		local l = Instance.new("Frame")  
		l.Size = size  
		l.Position = pos  
		l.BackgroundColor3 = Color3.fromRGB(255,0,0)  
		l.BorderSizePixel = 0  
		l.Parent = bill  
	end  

	line(UDim2.new(1,0,0,2),UDim2.new(0,0,0,0))  
	line(UDim2.new(1,0,0,2),UDim2.new(0,0,1,-2))  
	line(UDim2.new(0,2,1,0),UDim2.new(0,0,0,0))  
	line(UDim2.new(0,2,1,0),UDim2.new(1,-2,0,0))  

	bill.Parent = char  

	local nameGui = Instance.new("BillboardGui")  
	nameGui.Size = UDim2.new(0,150,0,40)  
	nameGui.Adornee = hrp  
	nameGui.AlwaysOnTop = true  
	nameGui.StudsOffset = Vector3.new(0,3,0)  

	local text = Instance.new("TextLabel",nameGui)  
	text.Size = UDim2.new(1,0,1,0)  
	text.BackgroundTransparency = 1  
	text.TextColor3 = Color3.new(1,1,1)  
	text.TextStrokeTransparency = 0  
	text.Font = Enum.Font.GothamBold  
	text.TextScaled = true  

	nameGui.Parent = char  

	espList[targetplayer] = {bill,nameGui}  

	RunService.RenderStepped:Connect(function()  
		if espEnabled and hum and hum.Parent then  
			text.Text = targetplayer.Name.." | ❤️ "..math.floor(hum.Health)  
		end  
	end)  

end  

if targetplayer.Character then  
	setup(targetplayer.Character)  
end  

targetplayer.CharacterAdded:Connect(setup)

end

local function clearESP()

for _,tbl in pairs(espList) do  
	for _,v in pairs(tbl) do  
		v:Destroy()  
	end  
end  

espList = {}

end

espToggle.MouseButton1Click:Connect(function()

espEnabled = not espEnabled
espToggle.Text = espEnabled and "ESP : ON" or "ESP : OFF"

if espEnabled then

	for _,p in pairs(Players:GetPlayers()) do
		if p ~= player then
			createESP(p)
		end
	end

	Players.PlayerAdded:Connect(function(p)
		createESP(p)
	end)

else
	clearESP()
end

end)

-- BUY AMOUNT SYSTEM
local UIS = game:GetService("UserInputService")

local dragging = false
local BuyAmount = 1
local maxBuy = 100

local function updateSlider(x)

local barPos = sliderBar.AbsolutePosition.X
local barSize = sliderBar.AbsoluteSize.X

local percent = math.clamp((x - barPos)/barSize,0,1)

sliderFill.Size = UDim2.new(percent,0,1,0)
sliderButton.Position = UDim2.new(percent,-9,0.5,-9)

BuyAmount = math.floor(1 + (maxBuy-1)*percent + 0.5)

amountLabel.Text = "BUY AMOUNT : "..BuyAmount

end

sliderBar.InputBegan:Connect(function(input)

if input.UserInputType == Enum.UserInputType.MouseButton1
or input.UserInputType == Enum.UserInputType.Touch then

dragging = true
updateSlider(input.Position.X)

end

end)

UIS.InputChanged:Connect(function(input)

if dragging then
updateSlider(input.Position.X)
end

end)

UIS.InputEnded:Connect(function()

dragging = false

end)

-- COUNT ITEM
local function countItem(name)

local amount = 0

local function check(container)

for _,v in pairs(container:GetChildren()) do

if v:IsA("Tool") then

if name == "Marshmallow Bag" then

if string.find(v.Name,"Marshmallow") then
amount += 1
end

else

if v.Name == name then
amount += 1
end

end

end

end

end

check(backpack)

if player.Character then
check(player.Character)
end

return amount

end

