local player = game.Players.LocalPlayer
local backpack = player:WaitForChild("Backpack")
local playerGui = player:WaitForChild("PlayerGui")

-- cari prompt npc
local prompt = workspace:WaitForChild("NPCs")
    :WaitForChild("Lamont Bell")
    :WaitForChild("UpperTorso")
    :WaitForChild("ProximityPrompt")

local selling = false

-- cari marshmallow bag
local function getBag()
	for _,v in pairs(backpack:GetChildren()) do
		if v:IsA("Tool") and string.find(v.Name,"Marshmallow") then
			return v
		end
	end
end

-- loop sell
local function sellLoop()
	while selling do

		local bag = getBag()

		if bag then
			local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")

			if hum then
				hum:EquipTool(bag)
			end

			task.wait(0.3)

			fireproximityprompt(prompt,0.5)

		end

		task.wait(0.8)
	end
end

-- GUI
local gui = Instance.new("ScreenGui")
gui.Name = "AutoSellGui"
gui.Parent = playerGui

local frame = Instance.new("Frame")
frame.Parent = gui
frame.Size = UDim2.new(0,200,0,60)
frame.Position = UDim2.new(0,50,0.5,0)
frame.BackgroundColor3 = Color3.fromRGB(30,30,30)

local button = Instance.new("TextButton")
button.Parent = frame
button.Size = UDim2.new(1,0,1,0)
button.Text = "AUTO SELL : OFF"
button.TextColor3 = Color3.new(1,1,1)
button.BackgroundTransparency = 1

button.MouseButton1Click:Connect(function()

	selling = not selling
	button.Text = selling and "AUTO SELL : ON" or "AUTO SELL : OFF"

	if selling then
		task.spawn(sellLoop)
	end

end)


