-- COUNT ITEM
-- ======================

local function countItem(name)

	local amount = 0

	local function check(container)

		for _,v in pairs(container:GetChildren()) do
			
			if name == "Marshmallow Bag" then
			
				if string.find(v.Name,"Marshmallow Bag") then
					amount += 1
				end
			
			else
			
				if v.Name == name then
					amount += 1
				end
			
			end
			
		end

	end

	check(backpack)

	if player.Character then
		check(player.Character)
	end

	return amount

end

-- AUTO FARM
local running = false

local function pressE()

vim:SendKeyEvent(true,Enum.KeyCode.E,false,game)
task.wait(0.1)
vim:SendKeyEvent(false,Enum.KeyCode.E,false,game)

end

local function equipTool(name)

local tool = backpack:FindFirstChild(name)

if tool then
player.Character.Humanoid:EquipTool(tool)
task.wait(0.4)
end

end

local function autoCook()

while running do

equipTool("Water")
pressE()
task.wait(21)

equipTool("Sugar Block Bag")
pressE()
task.wait(1)

equipTool("Gelatin")
pressE()
task.wait(46)

equipTool("Empty Bag")
pressE()
task.wait(2)

end

end

autoFarm.MouseButton1Click:Connect(function()

running = not running
autoFarm.Text = running and "AUTO FARM : ON" or "AUTO FARM : OFF"

if running then
task.spawn(autoCook)
end

end)

