-- Vehicle Teleport South Bronx (Stable)

local player = game.Players.LocalPlayer
local TweenService = game:GetService("TweenService")

-- lokasi tujuan
local npc = Vector3.new(523,3,615)
local stove = Vector3.new(1202,3,-182)

-- cari kendaraan yang sedang dinaiki
local function getSeat()

    local char = player.Character
    if not char then return end

    local humanoid = char:FindFirstChildOfClass("Humanoid")

    if humanoid and humanoid.SeatPart then
        return humanoid.SeatPart
    end

end

-- teleport kendaraan
local function teleport(pos)

    local seat = getSeat()

    if seat then

        local vehicle = seat.Parent

        for _,part in pairs(vehicle:GetDescendants()) do
            if part:IsA("BasePart") then

                local tween = TweenService:Create(
                    part,
                    TweenInfo.new(2, Enum.EasingStyle.Linear),
                    {CFrame = part.CFrame + (pos - seat.Position)}
                )

                tween:Play()

            end
        end

    end

end

-- GUI
local gui = Instance.new("ScreenGui", player.PlayerGui)

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0,180,0,120)
frame.Position = UDim2.new(0.02,0,0.35,0)
frame.BackgroundColor3 = Color3.fromRGB(30,30,30)
frame.Active = true
frame.Draggable = true
frame.Parent = gui

local btn1 = Instance.new("TextButton")
btn1.Size = UDim2.new(1,0,0,40)
btn1.Text = "TP NPC Marshmallow"
btn1.Parent = frame

local btn2 = Instance.new("TextButton")
btn2.Size = UDim2.new(1,0,0,40)
btn2.Position = UDim2.new(0,0,0,40)
btn2.Text = "TP Kompor"
btn2.Parent = frame

btn1.MouseButton1Click:Connect(function()
    teleport(npc)
end)

btn2.MouseButton1Click:Connect(function()
    teleport(stove)
end)
