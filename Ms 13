end

-- AUTO COOK

local cooking = false

local function autoCook()

	cooking = true

	while cooking do

		useTool("Water")
		pressCookingPotSafe()

		task.wait(21)

		useTool("Sugar Block Bag")
		useTool("Gelatin")

		pressCookingPotSafe()

		task.wait(46)

		useTool("Empty Bag")

		print("Marshmallow Finished")

		cooking = false

	end

end

