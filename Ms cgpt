-- BUTTON AUTO FARM
local autoFarm = Instance.new("TextButton")
autoFarm.Parent = main
autoFarm.Position = UDim2.new(0.05,0,0.55,0)
autoFarm.Size = UDim2.new(0.9,0,0,35)
autoFarm.Text = "AUTO COOK MARSHMALLOW"

local cooking = false

autoFarm.MouseButton1Click:Connect(function()

	if cooking then
		cooking = false
		autoFarm.Text = "AUTO COOK MARSHMALLOW"
		return
	end

	cooking = true
	autoFarm.Text = "STOP AUTO COOK"

	while cooking do

		local char = player.Character
		local humanoid = char:FindFirstChildOfClass("Humanoid")

		local waterTool = backpack:FindFirstChild("Water")
		local sugarTool = backpack:FindFirstChild("Sugar Block Bag")
		local gelatinTool = backpack:FindFirstChild("Gelatin")
		local bagTool = backpack:FindFirstChild("Empty Bag")

		if waterTool and sugarTool and gelatinTool and bagTool then

			humanoid:EquipTool(waterTool)
			task.wait(21)

			humanoid:EquipTool(sugarTool)
			humanoid:EquipTool(gelatinTool)

			task.wait(46)

			humanoid:EquipTool(bagTool)

		else
			print("Missing ingredients")
			break
		end

		task.wait(2)

	end

end)

-- BACKPACK SCANNER
task.spawn(function()

	while true do

		local waterCount = 0
		local sugarCount = 0
		local gelatinCount = 0
		local marshCount = 0

		for _,item in pairs(backpack:GetChildren()) do

			if item.Name == "Water" then
				waterCount += 1
			end

			if item.Name == "Sugar Block Bag" then
				sugarCount += 1
			end

			if item.Name == "Gelatin" then
				gelatinCount += 1
			end

			if item.Name == "Marshmallow"
			or item.Name == "Small Marshmallow Bag"
			or item.Name == "Medium Marshmallow Bag"
			or item.Name == "Large Marshmallow Bag" then
				marshCount += 1
			end

		end

		water.Text = "Water : "..waterCount
		sugar.Text = "Sugar : "..sugarCount
		gelatin.Text = "Gelatin : "..gelatinCount
		marshmallow.Text = "Marshmallow : "..marshCount

		task.wait(1)

	end

end)

