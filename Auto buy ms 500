local player = game.Players.LocalPlayer

local remote = game:GetService("ReplicatedStorage")
:WaitForChild("RemoteEvents")
:WaitForChild("StorePurchase")

local buying = false

-- GUI
local gui = Instance.new("ScreenGui")
gui.Parent = player:WaitForChild("PlayerGui")

local frame = Instance.new("Frame")
frame.Parent = gui
frame.Size = UDim2.new(0,200,0,90)
frame.Position = UDim2.new(0.5,-100,0.5,-45)
frame.BackgroundColor3 = Color3.fromRGB(40,40,40)
frame.Active = true
frame.Draggable = true

local button = Instance.new("TextButton")
button.Parent = frame
button.Size = UDim2.new(1,0,1,0)
button.Text = "AUTO BUY : OFF"
button.BackgroundColor3 = Color3.fromRGB(70,70,70)
button.TextColor3 = Color3.new(1,1,1)

-- AUTO BUY
button.MouseButton1Click:Connect(function()

    buying = not buying
    button.Text = buying and "AUTO BUY : ON" or "AUTO BUY : OFF"

    if buying then
        task.spawn(function()

            while buying do

                -- beli Water
                remote:FireServer("Water")
                task.wait(0.4)

                -- beli Sugar
                remote:FireServer("Sugar Block Bag")
                task.wait(0.4)

                -- beli Gelatin
                remote:FireServer("Gelatin")
                task.wait(0.4)

            end

        end)
    end

end)

