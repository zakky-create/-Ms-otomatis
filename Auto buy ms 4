-- fungsi pilih dialog "Yea... you the guy?" 2x
local function chooseDialogue()
    for i = 1,2 do
        for _,v in pairs(player.PlayerGui:GetDescendants()) do
            if v:IsA("TextButton") and string.find(v.Text,"Yea") then
                v:Activate()
                task.wait(0.5)
            end
        end
        task.wait(0.5)
    end
end

-- cari prompt Lamont Bell
local function getLamontPrompt()
    for _,v in pairs(workspace:GetDescendants()) do
        if v:IsA("ProximityPrompt") and v.Parent and v.Parent.Name:find("Lamont") then
            return v
        end
    end
end

-- buka shop Lamont Bell dengan hold lama
local function openShop()
    local prompt = getLamontPrompt()
    if prompt then
        fireproximityprompt(prompt,5) -- tahan 5 detik
    else
        warn("Prompt Lamont Bell tidak ditemukan")
    end
end

-- fungsi AutoBuy lengkap
local function autoBuy()

    -- buka shop
    openShop()
    task.wait(2)

    -- pilih dialog
    chooseDialogue()
    task.wait(1)

    -- beli Water, Sugar, Gelatin
    for i = 1,3 do
        fireproximityprompt(getLamontPrompt(),0.2)
        task.wait(0.8)
    end

    print("Water, Sugar, Gelatin berhasil dibeli")
end

-- konek tombol GUI
buyBtn.MouseButton1Click:Connect(function()
    autoBuy()
end)

