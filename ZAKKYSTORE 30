-- AUTO COOK SYSTEM
-- ======================

local running = false

local function pressE()
    vim:SendKeyEvent(true, Enum.KeyCode.E, false, game)
    task.wait(0.1)
    vim:SendKeyEvent(false, Enum.KeyCode.E, false, game)
end

local function equipTool(name)
    local tool = backpack:FindFirstChild(name)
    if tool then
        player.Character.Humanoid:EquipTool(tool)
        task.wait(0.4)
    end
end

local function autoCook()

    while running do

        equipTool("Water")
        pressE()

        task.wait(30)

        equipTool("Sugar Block Bag")
        pressE()

        task.wait(0.2)

        equipTool("Gelatin")
        pressE()

        task.wait(50)

        equipTool("Empty Bag")
        pressE() 
        
        task.wait(2) 
        
        print("Marshmallow selesai")

    end

end

-- tombol auto farm
autoFarm.MouseButton1Click:Connect(function()

    running = not running

    if running then
        autoFarm.Text = "AUTO FARM : ON"
        task.spawn(autoCook)
    else
        autoFarm.Text = "AUTO FARM : OFF"
    end

end)

-- ======================
-- TELEPORT SYSTEM
-- ======================

local TweenService = game:GetService("TweenService")

-- lokasi tujuan
local NPC = Vector3.new(523,3,615)
local APT1 = Vector3.new(1202,3,-182)

-- cari kendaraan yang sedang dinaiki
local function getSeat()

    local char = player.Character
    if not char then return end

    local humanoid = char:FindFirstChildOfClass("Humanoid")

    if humanoid and humanoid.SeatPart then
        return humanoid.SeatPart
    end

end

-- teleport kendaraan
local function teleport(pos)

    local seat = getSeat()

    if seat then

        local vehicle = seat.Parent

        for _,part in pairs(vehicle:GetDescendants()) do
            if part:IsA("BasePart") then

                local tween = TweenService:Create(
                    part,
                    TweenInfo.new(2, Enum.EasingStyle.Linear),
                    {CFrame = part.CFrame + (pos - seat.Position)}
                )

                tween:Play()

            end
        end

    end

end


-- ======================
-- HUBUNGKAN KE TOMBOL GUI
-- ======================

tpNPC.MouseButton1Click:Connect(function()
    teleport(NPC)
end)

tpAPT1.MouseButton1Click:Connect(function()
    teleport(APT1)
end)





