-- COUNT ITEM
local function countItem(name)

local amount = 0

local function check(container)

for _,v in pairs(container:GetChildren()) do

if name == "Marshmallow Bag" then

if string.find(v.Name,"Marshmallow Bag") then
amount += 1
end

else

if v.Name == name then
amount += 1
end

end

end

end

check(backpack)

if player.Character then
check(player.Character)
end

return amount

end

-- AUTO BUY
local buying = false

local function buy(item)
storeRemote:FireServer(item)
end

local function autoBuyLoop()

while buying do

while countItem("Water") < 1 do
buy("Water")
task.wait(0.4)
end

while countItem("Sugar Block Bag") < 1 do
buy("Sugar Block Bag")
task.wait(0.4)
end

while countItem("Gelatin") < 1 do
buy("Gelatin")
task.wait(0.4)
end

task.wait(1)

end

end

autoBuy.MouseButton1Click:Connect(function()

buying = not buying
autoBuy.Text = buying and "AUTO BUY : ON" or "AUTO BUY : OFF"

if buying then
task.spawn(autoBuyLoop)
end

end)

-- AUTO FARM
local running = false

local function pressE()

vim:SendKeyEvent(true,Enum.KeyCode.E,false,game)
task.wait(0.1)
