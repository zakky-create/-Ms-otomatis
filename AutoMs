local function createMainUI()
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "MarshmallowFarmUI"
    screenGui.ResetOnSpawn = false
    screenGui.Parent = playerGui
    
    -- Main Box (Draggable)
    local mainBox = Instance.new("Frame")
    mainBox.Name = "MainBox"
    mainBox.Size = UDim2.new(0, 150, 0, 60)
    mainBox.Position = UDim2.new(0, 20, 0.5, -30)
    mainBox.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    mainBox.BorderSizePixel = 2
    mainBox.BorderColor3 = Color3.fromRGB(100, 200, 255)
    mainBox.Parent = screenGui
    
    -- Draggable functionality
    local dragging = false
    local dragInput
    local dragStart
    local startPos
    
    mainBox.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = mainBox.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input, gameProcessed)
        if dragging and input.UserInputType == Enum.UserInputType.Mouse then
            local delta = input.Position - dragStart
            mainBox.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)
    
    -- Title Label
    local title = Instance.new("TextLabel")
    title.Name = "Title"
    title.Size = UDim2.new(1, 0, 0.6, 0)
    title.Position = UDim2.new(0, 0, 0, 0)
    title.BackgroundTransparency = 1
    title.Text = "MS Farm"
    title.TextColor3 = Color3.fromRGB(255, 255, 255)
    title.TextSize = 14
    title.Font = Enum.Font.GothamBold
    title.Parent = mainBox
    
    -- Open Button
    local openButton = Instance.new("TextButton")
    openButton.Name = "OpenButton"
    openButton.Size = UDim2.new(1, 0, 0.4, 0)
    openButton.Position = UDim2.new(0, 0, 0.6, 0)
    openButton.BackgroundColor3 = Color3.fromRGB(100, 200, 255)
    openButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    openButton.TextSize = 12
    openButton.Font = Enum.Font.Gotham
    openButton.Text = "Open"
    openButton.Parent = mainBox
    
    return screenGui, mainBox, openButton
end

