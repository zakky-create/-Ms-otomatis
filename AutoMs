local function initialize()
    -- Fetch player data (ownership, materials, marshmallows)
    -- This should connect to your game's data system
    
    State.ownedApartments.APT_1 = true -- Example: Set this based on actual game data
    State.materials.Water = 10
    State.materials.SugarBlockBag = 10
    State.materials.Gelatin = 10
    State.currentMarshmallows = 5
    
    -- Create main UI
    local screenGui, mainBox, openButton = createMainUI()
    
    -- Open menu on click
    openButton.MouseButton1Click:Connect(function()
        if not State.uiOpen then
            State.uiOpen = true
            createMenuUI()
        end
    end)
    
    -- Start auto cooking loop
    task.spawn(function()
        while true do
            task.wait(1)
            if State.isAutoMSEnabled then
                autoCookMarshmallows()
            end
        end
    end)
    
    -- Start anti-kick protection
    if CONFIG.ANTI_KICK_ENABLED then
        task.spawn(antiKickProtection)
    end
    
    -- Handle character respawn
    player.CharacterAdded:Connect(function(character)
        character:WaitForChild("HumanoidRootPart")
        updateActivity()
    end)
    
    print("✅ Marshmallow Farm Automation Script Loaded!")
    print("📍 NPC Location: X=" .. CONFIG.NPC_SELLER_LOCATION.X .. " Y=" .. CONFIG.NPC_SELLER_LOCATION.Y .. " Z=" .. CONFIG.NPC_SELLER_LOCATION.Z)
    print("📍 Stove Location: X=" .. CONFIG.STOVE_LOCATION.X .. " Y=" .. CONFIG.STOVE_LOCATION.Y .. " Z=" .. CONFIG.STOVE_LOCATION.Z)
end

-- Run initialization
initialize()

