local function findInventoryItem(itemName)
    -- This function should search the player's inventory and return the item
    -- Adjust based on your specific game's inventory structure
    local backpack = player:FindFirstChild("Backpack")
    if not backpack then return nil end
    
    return backpack:FindFirstChild(itemName)
end

local function interactWithStove()
    -- Find the stove in the game and interact with it
    local character = player.Character
    if not character then return end
    
    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
    if not humanoidRootPart then return end
    
    -- Move to stove location
    humanoidRootPart.CFrame = CFrame.new(CONFIG.STOVE_LOCATION + Vector3.new(0, 0, 5))
    task.wait(0.5)
    
    -- Find and interact with stove
    local stove = workspace:FindFirstChild("Stove") or workspace:FindFirstChild("CookingStove")
    if stove then
        -- Try to find interaction component
        local clickDetector = stove:FindFirstChild("ClickDetector")
        local proximityPrompt = stove:FindFirstChild("ProximityPrompt")
        
        if clickDetector then
            mouse.Target = stove
            mouse:TriggerButton1Down()
            task.wait(0.1)
            mouse:TriggerButton1Up()
        elseif proximityPrompt then
            fireproximityprompt(proximityPrompt)
        end
    end
    
    updateActivity()
end

local function interactWithNPC()
    -- Find the NPC and interact with it
    local character = player.Character
    if not character then return end
    
    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
    if not humanoidRootPart then return end
    
    -- Move to NPC location
    humanoidRootPart.CFrame = CFrame.new(CONFIG.NPC_SELLER_LOCATION + Vector3.new(0, 0, 5))
    task.wait(0.5)
    
    -- Find and interact with NPC
    local npc = workspace:FindFirstChild("NPCSeller") or workspace:FindFirstChild("MarshmallowSeller")
    if npc then
        local clickDetector = npc:FindFirstChild("ClickDetector")
        local proximityPrompt = npc:FindFirstChild("ProximityPrompt")
        
        if clickDetector then
            mouse.Target = npc
            mouse:TriggerButton1Down()
            task.wait(0.1)
            mouse:TriggerButton1Up()
        elseif proximityPrompt then
            fireproximityprompt(proximityPrompt)
        end
    end
    
    updateActivity()
end

-- ============================================================================
-- ANTI-KICK / ANTI-BAN PROTECTION
-- ============================================================================

local function updateActivity()
    State.lastActivityTime = tick()
end

local function antiKickProtection()
    while true do
        task.wait(CONFIG.RANDOM_MOVEMENT_INTERVAL)
        
        if not CONFIG.ANTI_KICK_ENABLED then continue end
        
        local character = player.Character
        if not character then continue end
        
        local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
        if not humanoidRootPart then continue end
        
        -- Random small movement
        local randomOffset = Vector3.new(
            math.random(-5, 5),
            0,
            math.random(-5, 5)
        )
        humanoidRootPart.CFrame = humanoidRootPart.CFrame + randomOffset
        
        -- Random mouse movement
        if CONFIG.RANDOM_MOUSE_MOVEMENT then
            mouse.Move = mouse.X + math.random(-20, 20)
        end
        
        updateActivity()
    end
end

