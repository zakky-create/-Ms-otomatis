local function sellMarshmallowRoutine(bagType)
    local character = player.Character
    if not character then return end
    
    -- Find and click the marshmallow bag in inventory
    local bag = findInventoryItem(bagType)
    if not bag then
        print("Bag not found: " .. bagType)
        return
    end
    
    task.wait(0.5)
    
    -- Interact with NPC seller
    interactWithNPC()
    task.wait(1)
    
    updateActivity()
end

