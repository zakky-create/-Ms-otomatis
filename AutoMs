    task.wait(1)
    screenGui:Destroy()
    
    updateActivity()
end

-- ============================================================================
-- AUTO BUY MATERIALS ROUTINE
-- ============================================================================

local function buyMaterialsRoutine(quantity)
    teleportWithAnimation(CONFIG.NPC_SELLER_LOCATION)
    task.wait(2)
    
    local character = player.Character
    if not character then return end
    
    for i = 1, quantity do
        if not (player.Character and player.Character:FindFirstChild("HumanoidRootPart")) then break end
        
        -- Press Water
        local waterButton = findInventoryItem("Water")
        if waterButton then waterButton.Position = Vector3.new(0, 0, 0) end
        task.wait(0.5)
        
        -- Press Sugar Block Bag
        local sugarButton = findInventoryItem("Sugar Block Bag")
        if sugarButton then sugarButton.Position = Vector3.new(0, 0, 0) end
        task.wait(0.5)
        
        -- Press Gelatin
        local gelatinButton = findInventoryItem("Gelatin")
        if gelatinButton then gelatinButton.Position = Vector3.new(0, 0, 0) end
        task.wait(0.5)
        
        updateActivity()
        
        if i % 10 == 0 then
            task.wait(2) -- Brief pause every 10 purchases
        end
    end
end

-- ============================================================================
-- AUTO COOKING ROUTINE
-- ============================================================================

local function autoCookMarshmallows()
    if State.isCooking then return end
    State.isCooking = true
    
    local marshmallowsMade = 0
    local targetMarshmallows = State.materialsToMake
    
    while State.isAutoMSEnabled and marshmallowsMade < targetMarshmallows do
        local character = player.Character
        if not character or not character:FindFirstChild("HumanoidRootPart") then break end
        
        -- Step 1: Press Water in inventory
        local waterItem = findInventoryItem("Water")
        if not waterItem then break end
        task.wait(0.5)
        updateActivity()
        
        -- Step 2: Press Interact on the stove
        interactWithStove()
        task.wait(0.5)
        updateActivity()
        
        -- Step 3: Wait 21 seconds
        task.wait(CONFIG.STOVE_WAIT_TIME)
        updateActivity()
        
        -- Step 4: Press Sugar Block Bag
        local sugarItem = findInventoryItem("Sugar Block Bag")
        if not sugarItem then break end
        task.wait(0.5)
        updateActivity()
        
        -- Step 5: Press Gelatin
        local gelatinItem = findInventoryItem("Gelatin")
        if not gelatinItem then break end
        task.wait(0.5)
        updateActivity()
        
        -- Step 6: Press Interact on the stove again
        interactWithStove()
        task.wait(0.5)
        updateActivity()
        
        -- Step 7: Wait 46 seconds
        task.wait(CONFIG.SECOND_COOK_WAIT_TIME)
        updateActivity()
        
        -- Step 8: Press Blank Bag in inventory
        local blankBag = findInventoryItem("Blank Bag")
        if not blankBag then break end
        task.wait(0.5)
        updateActivity()
        
        marshmallowsMade = marshmallowsMade + 1
        State.currentMarshmallows = marshmallowsMade
        
        task.wait(1) -- Small delay between batches
    end
    
    State.isCooking = false
    State.isAutoMSEnabled = false
end

