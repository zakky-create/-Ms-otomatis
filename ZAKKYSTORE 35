-- ======================
-- AUTO SELL SYSTEM
-- ======================

local selling = false

local function isMarshmallow(name)

    return string.find(name,"Marshmallow Bag")

end


local function autoSellFunc()

    while selling do

        for _,tool in pairs(backpack:GetChildren()) do

            if not selling then break end

            if tool:IsA("Tool") and isMarshmallow(tool.Name) then

                player.Character.Humanoid:EquipTool(tool)

                task.wait(0.4)

                pressE() -- jual ke NPC

                task.wait(0.8)

            end

        end

        task.wait(1)

    end

endend



