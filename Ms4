local function safeGetCharacter()
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        return char
    end
    return nil
end

local function safeGetHumanoidRootPart()
    local char = safeGetCharacter()
    if char then
        return char:FindFirstChild("HumanoidRootPart")
    end
    return nil
end

local function findNPC(npcName)
    local workspace = game:GetService("Workspace")
    local npc = workspace:FindFirstChild(npcName)
    if npc then return npc end
    
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj.Name == npcName and obj:FindFirstChild("HumanoidRootPart") then
            return obj
        end
    end
    return nil
end

local function findProximityPromptNear(location, radius)
    pcall(function()
        local workspace = game:GetService("Workspace")
        local parts = workspace:FindPartBoundsInRadius(location, radius)
        
        for _, part in pairs(parts) do
            local prompt = part:FindFirstChild("ProximityPrompt")
            if prompt then
                return prompt
            end
        end
    end)
    return nil
end

local function triggerProximityPrompt(prompt)
    if not prompt or not prompt:IsA("ProximityPrompt") then
        return false
    end
    
    pcall(function()
        fireproximityprompt(prompt)
    end)
    return true
end

local function teleportToPosition(targetPos, offset)
    local hrp = safeGetHumanoidRootPart()
    if not hrp then
        print("❌ Cannot teleport: HumanoidRootPart not found")
        return false
    end
    
    local safePos = targetPos + offset
    pcall(function()
        hrp.CFrame = CFrame.new(safePos)
    end)
    
    task.wait(0.5)
    return true
end

