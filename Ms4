-- ============================================================================

function buyMaterialsRoutine(quantity)
    print("💰 Starting to buy " .. quantity .. " materials...")
    teleportToPosition(CONFIG.NPC_SELLER_LOCATION, CONFIG.NPC_APPROACH_OFFSET)
    task.wait(2)
    
    for i = 1, quantity do
        if not safeGetCharacter() then break end
        
        local prompt = findProximityPromptNear(CONFIG.NPC_SELLER_LOCATION, 30)
        if prompt then
            triggerProximityPrompt(prompt)
        end
        
        task.wait(0.5)
    end
    
    print("✅ Buying complete!")
end

function autoCookMarshmallows()
    if State.isCooking then return end
    State.isCooking = true
    
    local marshmallowsMade = 0
    
    while State.isAutoMSEnabled and marshmallowsMade < State.materialsToMake do
        if not safeGetCharacter() then break end
        
        teleportToPosition(CONFIG.STOVE_LOCATION, CONFIG.STOVE_APPROACH_OFFSET)
        task.wait(1)
        
        local prompt = findProximityPromptNear(CONFIG.STOVE_LOCATION, 30)
        if prompt then
            triggerProximityPrompt(prompt)
        end
        
        task.wait(CONFIG.STOVE_WAIT_TIME)
        task.wait(CONFIG.SECOND_COOK_WAIT_TIME)
        
        marshmallowsMade = marshmallowsMade + 1
        State.currentMarshmallows = marshmallowsMade
        
        task.wait(1)
    end
    
    State.isCooking = false
    State.isAutoMSEnabled = false
    print("✅ Cooking complete!")
end

