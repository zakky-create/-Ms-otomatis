    State.materials.SugarBlockBag = 10
    State.materials.Gelatin = 10
    
    local screenGui, mainBox, openButton = createMainUI()
    
    openButton.MouseButton1Click:Connect(function()
        if not State.uiOpen then
            State.uiOpen = true
            createMenuUI()
        end
    end)
    
    task.spawn(function()
        while true do
            task.wait(1)
            if State.isAutoMSEnabled then
                autoCookMarshmallows()
            end
        end
    end)
    
    player.CharacterAdded:Connect(function(character)
        character:WaitForChild("HumanoidRootPart")
    end)
    
    print("✅ Marshmallow Farm Script Ready!")
    print("📍 NPC Lamont Bell: X=510, Y=10, Z=597")
    print("📍 Stove: X=1202, Y=10, Z=-182")
end

initialize()

