local function createESP(targetplayer)
  if not espEnabled then return end

if targetplayer == player then return end  

local function setup(char)  

	local hrp = char:WaitForChild("HumanoidRootPart",5)  
	local hum = char:WaitForChild("Humanoid",5)  
	if not hrp then return end  

    for _,v in pairs(char:GetChildren()) do
    if v:IsA("BillboardGui") or v:IsA("Highlight") then
        v:Destroy()
    end
end

    -- 3D ESP (Highlight)
    local highlight = Instance.new("Highlight")
    highlight.FillTransparency = 1
    highlight.OutlineColor = Color3.fromRGB(255,0,0)
    highlight.OutlineTransparency = 0
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Parent = char

	local nameGui = Instance.new("BillboardGui")  
	nameGui.Size = UDim2.new(0,150,0,40)  
	nameGui.Adornee = hrp  
	nameGui.AlwaysOnTop = true  
	nameGui.StudsOffset = Vector3.new(0,3,0)  

	local text = Instance.new("TextLabel",nameGui)  
	text.Size = UDim2.new(1,0,1,0)  
	text.BackgroundTransparency = 1  
	text.TextColor3 = Color3.new(1,1,1)  
	text.TextStrokeTransparency = 0  
	text.Font = Enum.Font.GothamBold  
	text.TextScaled = true  

	nameGui.Parent = char  

	espList[targetplayer] = {highlight,nameGui}  

	RunService.RenderStepped:Connect(function()  
		if espEnabled and hum and hum.Parent then  
			text.Text = targetplayer.Name.." | ❤️ "..math.floor(hum.Health)  
		end  
	end)  

end  

if targetplayer.Character then  
	setup(targetplayer.Character)  
end  

targetplayer.CharacterAdded:Connect(setup)

end

local function clearESP()

for _,tbl in pairs(espList) do  
	for _,v in pairs(tbl) do  
		v:Destroy()  
	end  
end  

espList = {}

end

espToggle.MouseButton1Click:Connect(function()

espEnabled = not espEnabled
espToggle.Text = espEnabled and "ESP : ON" or "ESP : OFF"

if espEnabled then

	for _,p in pairs(Players:GetPlayers()) do
		if p ~= player then
			createESP(p)
		end
