-- AUTO SELL GUI HP

local player = game.Players.LocalPlayer
local backpack = player:WaitForChild("Backpack")
local prompt = workspace.Folders.NPCs["Lamont Bell"].UpperTorso.ProximityPrompt

local selling = false

-- GUI
local gui = Instance.new("ScreenGui")
gui.Parent = game.CoreGui
gui.ResetOnSpawn = false

local frame = Instance.new("Frame")
frame.Parent = gui
frame.Size = UDim2.new(0,200,0,60)
frame.Position = UDim2.new(0.4,0,0.4,0)
frame.BackgroundColor3 = Color3.fromRGB(30,30,30)
frame.Active = true
frame.Draggable = true -- banyak executor HP tetap support ini

local button = Instance.new("TextButton")
button.Parent = frame
button.Size = UDim2.new(1,0,1,0)
button.Text = "AUTO SELL : OFF"
button.TextScaled = true
button.BackgroundTransparency = 1
button.TextColor3 = Color3.new(1,1,1)

-- cari marshmallow bag
local function getBag()
	for _,v in pairs(backpack:GetChildren()) do
		if v:IsA("Tool") and string.find(v.Name,"Marshmallow") then
			return v
		end
	end
end

-- auto sell loop
local function autoSell()

	while selling do

		local bag = getBag()

		if bag then

			local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")

			if hum then
				hum:EquipTool(bag)
			end

			task.wait(0.3)

			fireproximityprompt(prompt,0.5)

		end

		task.wait(0.8)

	end

end

-- tombol ON OFF
button.Activated:Connect(function()

	selling = not selling

	if selling then
		button.Text = "AUTO SELL : ON"
		task.spawn(autoSell)
	else
		button.Text = "AUTO SELL : OFF"
	end

end)


