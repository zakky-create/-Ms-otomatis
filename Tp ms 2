-- teleport step lambat
local function stepTP(target)

    stopTP = false

    local char = player.Character
    if not char then return end

    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    while (root.Position - target).Magnitude > 5 and not stopTP do
        root.CFrame = root.CFrame + (target - root.Position).Unit * 20
        task.wait(0.15)
    end

    if not stopTP then
        root.CFrame = CFrame.new(target)
    end

end

npcBtn.MouseButton1Click:Connect(function()
    stepTP(npcPos)
end)

stoveBtn.MouseButton1Click:Connect(function()
    stepTP(stovePos)
end)

stopBtn.MouseButton1Click:Connect(function()
    stopTP = true
end)

